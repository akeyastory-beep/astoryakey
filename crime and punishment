            <div class="sidebar-stat"><span class="sidebar-stat-label">Genre</span><span class="sidebar-stat-value"> Psychological fiction</span></div>
            <div class="sidebar-stat"><span class="sidebar-stat-label">Difficulty</span><span class="sidebar-stat-value">Challenging</span></div>
          </div>

          <div class="sidebar-card">
